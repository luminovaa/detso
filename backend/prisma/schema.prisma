generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model Detso_Tenant {
  id                String                     @id @default(cuid())
  name              String                     @unique
  slug              String                     @unique
  logo              String?
  address           String?
  phone             String?
  is_active         Boolean                    @default(true)
  deleted_at        DateTime?
  created_at        DateTime                   @default(now())
  updated_at        DateTime                   @updatedAt
  lat               String?
  long              String?
  customers         Detso_Customer[]
  packages          Detso_Package[]
  services          Detso_Service_Connection[]
  tickets           Detso_Ticket[]
  users             Detso_User[]
  schedules         Detso_Work_Schedule[]
  network_nodes     Detso_Network_Node[]
  network_links     Detso_Network_Link[]

  @@index([deleted_at])
  @@map("detso_tenants")
}

model Detso_User {
  id             String                 @id @default(cuid())
  tenant_id      String?
  username       String
  email          String                 @unique
  password       String
  phone          String?
  role           Detso_Role             @default(TENANT_TEKNISI)
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  deleted_at     DateTime?
  profile        Detso_Profile?
  refresh_tokens Detso_Refresh_Token[]
  ticket_history Detso_Ticket_History[]
  ticket         Detso_Ticket[]
  tenant         Detso_Tenant?          @relation(fields: [tenant_id], references: [id])
  schedule       Detso_Work_Schedule[]

  @@index([tenant_id])
  @@index([deleted_at])
  @@map("detso_users")
}

model Detso_Profile {
  id         String     @id @default(cuid())
  user_id    String     @unique
  full_name  String
  avatar     String?
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  deleted_at DateTime?
  user       Detso_User @relation(fields: [user_id], references: [id])

  @@index([deleted_at])
  @@map("detso_profiles")
}

model Detso_Refresh_Token {
  id           String     @id @default(cuid())
  user_id      String
  token        String     @unique
  device_info  String?
  ip_address   String?
  user_agent   String?
  expires_at   DateTime
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  revoked_at   DateTime?
  is_active    Boolean    @default(true)
  last_used_at DateTime?
  rotated_from String?
  user         Detso_User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@index([last_used_at])
  @@map("detso_refresh_tokens")
}

model Detso_Customer {
  id           String                     @id @default(cuid())
  tenant_id    String
  name         String
  phone        String?
  email        String?
  nik          String?
  address      String?
  birth_date   DateTime?
  birth_place  String?
  created_at   DateTime                   @default(now())
  updated_at   DateTime                   @updatedAt
  deleted_at   DateTime?
  documents    Detso_Customer_Document[]
  pdf          Detso_Customer_PDF[]
  tenant       Detso_Tenant               @relation(fields: [tenant_id], references: [id])
  service      Detso_Service_Connection[]
  ticket       Detso_Ticket[]

  @@index([tenant_id])
  @@index([deleted_at])
  @@index([phone])
  @@index([nik])
  @@map("detso_customers")
}

model Detso_Customer_Document {
  id            String          @id @default(cuid())
  customer_id   String?
  document_type String
  document_url  String
  uploaded_at   DateTime        @default(now())
  customer      Detso_Customer? @relation(fields: [customer_id], references: [id])

  @@index([customer_id])
  @@map("detso_customer_documents")
}

model Detso_Service_Connection {
  id            String                @id @default(cuid())
  tenant_id     String
  customer_id   String
  id_pel        String?
  package_id    String
  address       String?
  package_name  String
  package_speed String
  package_price Int?
  ip_address    String?
  lat           String?
  long          String?
  mac_address   String?
  status        Detso_Customer_Status @default(ACTIVE)
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt
  deleted_at    DateTime?
  notes         String?
  pdf           Detso_Customer_PDF[]
  customer      Detso_Customer        @relation(fields: [customer_id], references: [id])
  package       Detso_Package         @relation(fields: [package_id], references: [id])
  tenant        Detso_Tenant          @relation(fields: [tenant_id], references: [id])
  photos        Detso_Service_Photo[]
  ticket        Detso_Ticket[]
  network_link  Detso_Network_Link?

  @@index([tenant_id])
  @@index([deleted_at])
  @@map("detso_service_connections")
}

model Detso_Service_Photo {
  id          String                   @id @default(cuid())
  service_id  String
  photo_type  String
  photo_url   String
  uploaded_at DateTime                 @default(now())
  notes       String?
  service     Detso_Service_Connection @relation(fields: [service_id], references: [id])

  @@index([service_id])
  @@map("detso_service_photos")
}

model Detso_Customer_PDF {
  id                    String                   @id @default(cuid())
  customer_id           String
  service_connection_id String
  pdf_type              String                   @default("installation_report")
  pdf_path              String
  generated_at          DateTime                 @default(now())
  customer              Detso_Customer           @relation(fields: [customer_id], references: [id])
  service_connection    Detso_Service_Connection @relation(fields: [service_connection_id], references: [id])

  @@map("detso_customer_pdfs")
}

model Detso_Package {
  id         String                     @id @default(cuid())
  tenant_id  String
  name       String
  speed      String
  price      Int
  deleted_at DateTime?
  created_at DateTime                   @default(now())
  updated_at DateTime                   @updatedAt
  tenant     Detso_Tenant               @relation(fields: [tenant_id], references: [id])
  service    Detso_Service_Connection[]

  @@index([tenant_id])
  @@map("detso_packages")
}

model Detso_Ticket {
  id             String                    @id @default(cuid())
  tenant_id      String
  customer_id    String
  service_id     String?
  title          String
  description    String
  type           TicketType                @default(PROBLEM)
  priority       TicketPriority            @default(MEDIUM)
  status         TicketStatus              @default(OPEN)
  assigned_to    String?
  created_at     DateTime                  @default(now())
  updated_at     DateTime                  @updatedAt
  resolved_at    DateTime?
  deleted_at     DateTime?
  ticket_history Detso_Ticket_History[]
  technician     Detso_User?               @relation(fields: [assigned_to], references: [id])
  customer       Detso_Customer            @relation(fields: [customer_id], references: [id])
  service        Detso_Service_Connection? @relation(fields: [service_id], references: [id])
  tenant         Detso_Tenant              @relation(fields: [tenant_id], references: [id])
  schedule       Detso_Work_Schedule?

  @@index([tenant_id])
  @@index([type])
  @@index([status])
  @@index([customer_id])
  @@index([assigned_to])
  @@map("detso_tickets")
}

model Detso_Ticket_History {
  id          String       @id @default(cuid())
  ticket_id   String
  action      TicketAction
  description String?
  image       String?
  created_by  String?
  created_at  DateTime     @default(now())
  user        Detso_User?  @relation(fields: [created_by], references: [id])
  ticket      Detso_Ticket @relation(fields: [ticket_id], references: [id])

  @@map("detso_ticket_history")
}

model Detso_Work_Schedule {
  id            String         @id @default(cuid())
  tenant_id     String
  title         String?
  ticket_id     String?        @unique
  technician_id String
  start_time    DateTime
  end_time      DateTime?
  status        ScheduleStatus @default(SCHEDULED)
  notes         String?
  created_at    DateTime       @default(now())
  updated_at    DateTime?
  technician    Detso_User     @relation(fields: [technician_id], references: [id])
  tenant        Detso_Tenant   @relation(fields: [tenant_id], references: [id])
  ticket        Detso_Ticket?  @relation(fields: [ticket_id], references: [id])

  @@index([tenant_id])
  @@map("detso_work_schedules")
}

enum TicketAction {
  CREATED
  UPDATED
  ASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  RESOLVED
  CLOSED
  REOPENED
  SCHEDULED
  NOTE_ADDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ScheduleStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum Detso_Customer_Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Detso_Role {
  SAAS_SUPER_ADMIN
  TENANT_OWNER
  TENANT_ADMIN
  TENANT_TEKNISI
}

enum TicketType {
  UPGRADE
  DOWNGRADE
  PROBLEM
}

// ─── Network Topology ────────────────────────────────────────────

enum Detso_Network_Node_Type {
  SERVER
  ODP
}

enum Detso_Link_Type {
  FIBER
  DROP_CABLE
}

model Detso_Network_Node {
  id         String                  @id @default(cuid())
  tenant_id  String
  type       Detso_Network_Node_Type
  name       String
  lat        String
  long       String
  address    String?
  slot       Int?
  notes      String?
  parent_id  String?
  created_at DateTime                @default(now())
  updated_at DateTime                @updatedAt
  deleted_at DateTime?

  tenant     Detso_Tenant            @relation(fields: [tenant_id], references: [id])
  parent     Detso_Network_Node?     @relation("NodeHierarchy", fields: [parent_id], references: [id])
  children   Detso_Network_Node[]    @relation("NodeHierarchy")
  links_from Detso_Network_Link[]    @relation("LinkFrom")
  links_to   Detso_Network_Link[]    @relation("LinkTo")

  @@index([tenant_id])
  @@index([type])
  @@index([parent_id])
  @@index([deleted_at])
  @@map("detso_network_nodes")
}

model Detso_Network_Link {
  id            String                    @id @default(cuid())
  tenant_id     String
  from_node_id  String
  to_node_id    String?
  to_service_id String?                   @unique
  type          Detso_Link_Type
  waypoints     Json?
  notes         String?
  created_at    DateTime                  @default(now())
  updated_at    DateTime                  @updatedAt

  tenant        Detso_Tenant              @relation(fields: [tenant_id], references: [id])
  from_node     Detso_Network_Node        @relation("LinkFrom", fields: [from_node_id], references: [id])
  to_node       Detso_Network_Node?       @relation("LinkTo", fields: [to_node_id], references: [id])
  to_service    Detso_Service_Connection? @relation(fields: [to_service_id], references: [id])

  @@index([tenant_id])
  @@index([from_node_id])
  @@index([to_node_id])
  @@index([to_service_id])
  @@map("detso_network_links")
}
